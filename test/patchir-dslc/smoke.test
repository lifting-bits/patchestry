# Smoke test: patchir-dslc binary is built, substitution is wired, and
# --help lists every Phase 1 flag. The stub input-handling is also
# exercised here (missing file produces a clean diagnostic).

# RUN: %patchir-dslc --help 2>&1 | %file-check %s
# RUN: not %patchir-dslc --check /tmp/nonexistent-for-lit-smoke.patch 2>&1 | %file-check %s --check-prefix=MISSING

# CHECK:      patchir-dslc: compile PatchDSL to .patchmod
# CHECK:      -I <dir>
# CHECK-NEXT: --check
# CHECK-NEXT: --dump-config
# CHECK-NEXT: -o <filename>

# MISSING: patchir-dslc: failed to read `/tmp/nonexistent-for-lit-smoke.patch`
