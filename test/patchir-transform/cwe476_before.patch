// PatchDSL port of cwe476_before.yaml
// library: patches/cwe476_patches.yaml

metadata {
  name:        "cwe476-apply_before"
  description: "Inject null pointer check before get_name"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2026-03-17"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_get_name.c" as nullcheck

rule cwe476_get_name_fix {
  description: "Check for NULL pointer before method call"

  pattern-inside: $RET poke_process(...) { ... }
  pattern:        get_name($OBJ)

  insert before:
    call: nullcheck::patch__before__get_name__null_check($OBJ)
}
