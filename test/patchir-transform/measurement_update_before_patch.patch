// PatchDSL port of measurement_update_before_patch.yaml
// library: patches/measurement_update_patch.yaml

metadata {
  name:        "measurement-update-before-patch"
  description: "Patch measurement update before function"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-07-28"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_spo2_lookup.c" as spo2

rule measurement_update_before_patch {
  description: "Apply measurement update patch before spo2_lookup"

  pattern: spo2_lookup(($X: float))

  insert before:
    call: spo2::patch__before__spo2_lookup($X)
}
