// PatchDSL port of measurement_update_before_operation.yaml
// library: patches/measurement_update_patch.yaml

metadata {
  name:        "measurement-update-before-operation"
  description: "Patch measurement update before spo2_lookup call-site"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-07-28"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_spo2_lookup.c" as spo2

rule measurement_update_before_operation {
  description: "Insert patch before spo2_lookup inside any *measurement*update* function"

  pattern-inside: |
    $RET $FN(...) { ... }
  capture-comparison: { var: $FN,
                        cmp: matches("measurement") && matches("update") }

  pattern: spo2_lookup(($X: float))

  insert before:
    call: spo2::patch__before__spo2_lookup($X)
}
