// PatchDSL port of bl_usb__send_message_before_update_patch.yaml
// library: patches/usb_security_patches.yaml
//
// Operands are passed by reference (legacy is_reference: true) — spelled
// &$capture in PatchDSL.

metadata {
  name:        "usb-security-monitoring-deployment"
  description: "Update-state variant - operands passed by reference"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-06-31"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_usbd_ep_write_packet.c" as usb

rule usb_security_before_packet_write_update_state {
  description: "Pre-validation with by-reference operands"

  pattern-inside: $RET bl_usb__send_message(...) { ... }
  pattern:        usbd_ep_write_packet(
                     ($USB_G: struct _usbd_device*),
                     $EP,
                     ($BUF: void*),
                     $LEN)

  insert before:
    call: usb::patch__before__usbd_cp_write_packet__update_state(&$USB_G, &$BUF)
}
