// PatchDSL port of measurement_update_after_patch.yaml
// library: patches/measurement_update_patch.yaml

metadata {
  name:        "measurement-update-after-patch"
  description: "Patch measurement update after function"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-07-28"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_spo2_lookup.c" as spo2

rule measurement_update_after_patch {
  description: "Apply measurement update patch after spo2_lookup"

  // $RV binds the return value of the matched call
  pattern: ($RV: uint8_t) = spo2_lookup(...)

  insert after:
    call: spo2::patch__after__spo2_lookup($RV)
}
