// Capture tests on real firmware function data__allocate_filter (bloodview).
// The function computes a size (one add + one mul), calls realloc, and on
// a non-null result, does another (mul + add) calculation then memset.
//
// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -use-structuring-pass -emit-cir -output %t1 >> /dev/null 2>&1
//
// Test 1: capture both operands of the mul binop, replace with checked_mul.
// RUN: %patchir-transform %t1.cir --spec %S/capture_allocate_filter_mul.yaml -o %t2.cir
// RUN: %file-check -vv -check-prefix=MUL %s --input-file %t2.cir
// MUL: cir.call @patch__replace__int_mul({{.*}}) {patchestry_operation = "cir.binop"}
//
// Test 2: index-based operand references produce byte-identical CIR.
// RUN: %patchir-transform %t1.cir --spec %S/capture_allocate_filter_mul_index.yaml -o %t3.cir
// RUN: diff %t2.cir %t3.cir
//
// Test 3: capture on a cir.call — bind size operand of realloc, replace with
// checked_mul (abusing the patch to show the capture flows through).
// RUN: %patchir-transform %t1.cir --spec %S/capture_allocate_filter_realloc.yaml -o %t4.cir
// RUN: %file-check -vv -check-prefix=RCALL %s --input-file %t4.cir
// RCALL: cir.call @patch__replace__int_mul
