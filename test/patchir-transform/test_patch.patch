// PatchDSL port of test_patch.yaml
// library: patches/usb_security_patches.yaml, contracts/usb_security_contracts.yaml
//
// Legacy source: variable, symbol: var1 passes a named local alloca;
// PatchDSL binds it with a capture ($var1) inside pattern-inside: whose
// body declares $var1.

metadata {
  name:        "usb-security-monitoring-deployment"
  description: "Test patch with variable-source argument"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-06-31"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32" }
}

import "patches/patch_usbd_ep_write_packet.c" as usb

rule usb_security_with_local_var {
  description: "Pre-validation using local variable var1"

  pattern-inside: $RET bl_usb__send_message(...) {
    ...
    $T $var1 = ...;
    ...
  }
  pattern: usbd_ep_write_packet(
              ($USB_G: struct _usbd_device*),
              $...REST)

  insert before:
    call: usb::patch__before__usbd_ep_write_packet($USB_G, $var1)
}
