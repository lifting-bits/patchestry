// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -use-structuring-pass -emit-cir -output %t1 >> /dev/null 2>&1
//
// Verify apply_before inserts a marker call immediately ahead of the
// matched test_function invocation.
//
// RUN: %patchir-transform %t1.cir --spec %S/basic_transform.test.yaml -o %t2.cir
// RUN: %file-check -check-prefix=YAML %s --input-file %t2.cir
// YAML: cir.call @patch__before__test_function() {patchestry_operation = "cir.call"}
// YAML: cir.call @test_function(
//
{
  "architecture": "ARM",
  "id": "ARM:LE:32:Cortex",
  "format": "Executable and Linking Format (ELF)",
  "functions": {
    "ram:10000000": {
      "name": "caller",
      "is_intrinsic": false,
      "type": {
        "return_type": "t_void",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": []
      },
      "basic_blocks": {
        "ram:10000000:entry": {
          "operations": {
            "entry.exit": {
              "mnemonic": "BRANCH",
              "inputs": []
            }
          },
          "ordered_operations": ["entry.exit"]
        },
        "ram:10000004:0:basic": {
          "operations": {
            "ram:10000004:100:0": {
              "mnemonic": "CALL",
              "type": "t_u32",
              "output": null,
              "has_return_value": true,
              "target": {
                "kind": "function",
                "function": "EXTERNAL:00000001",
                "is_variadic": false,
                "is_noreturn": false
              },
              "inputs": [
                {
                  "type": "t_u32",
                  "kind": "constant",
                  "value": 42
                }
              ]
            },
            "ram:10000008:101:0": {
              "mnemonic": "RETURN",
              "inputs": []
            }
          },
          "ordered_operations": [
            "ram:10000004:100:0",
            "ram:10000008:101:0"
          ]
        }
      },
      "entry_block": "ram:10000000:entry"
    },
    "EXTERNAL:00000001": {
      "name": "test_function",
      "is_intrinsic": false,
      "type": {
        "return_type": "t_u32",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": ["t_u32"]
      }
    }
  },
  "types": {
    "t_void": {
      "name": "void",
      "size": 0,
      "kind": "void"
    },
    "t_u32": {
      "name": "unsigned int",
      "size": 4,
      "kind": "integer",
      "is_signed": false
    }
  },
  "globals": {}
}
