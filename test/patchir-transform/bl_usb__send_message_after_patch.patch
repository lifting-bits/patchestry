// PatchDSL port of bl_usb__send_message_after_patch.yaml
// library: patches/usb_security_patches.yaml

metadata {
  name:        "usb-security-monitoring-deployment"
  description: "Deploy USB security monitoring for medical device firmware (after)"
  version:     "1.0.0"
  author:      "Security Team"
  created:     "2025-06-31"
  target { binary: "test_binary.bin"  arch: "ARM:LE:32:Cortex" }
}

import "patches/patch_usbd_ep_write_packet.c" as usb

rule usb_security_after_packet_write {
  description: "Checks function return value"

  pattern-inside: $RET bl_usb__send_message(...) { ... }
  pattern:        ($RV: uint32_t) = usbd_ep_write_packet(
                     ($USB_G: struct _usbd_device*), $...REST)

  insert after:
    call: usb::patch__after__usbd_ep_write_packet($RV)
}
