// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -emit-cir -output %t_s1 >> /dev/null 2>&1
// RUN: %patchir-transform %t_s1.cir --spec %S/cwe476_klee_spec.yaml -o %t_s2.cir
// RUN: %patchir-cir2llvm %t_s2.cir -S -o %t_s3.ll
// RUN: %patchir-klee-verifier %t_s3.ll --target-function poke_process -S -o %t_harness.ll
// RUN: %file-check -check-prefix=KLEE %s --input-file %t_harness.ll

// E2E test: ventilator_cwe476.json → decomp → transform (patch + static contract) → cir2llvm → klee-verifier
