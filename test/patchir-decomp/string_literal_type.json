// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -use-structuring-pass -emit-cir -emit-llvm -print-tu -output %t >> /dev/null 2>&1
// RUN: test -e %t.c
// RUN: %file-check -vv -check-prefix=CIR %s --input-file %t.cir
// CIR: cir.const_array<"hello %s
// CIR: cir.func @string_literal_test
// RUN: %file-check -vv -check-prefix=LL %s --input-file %t.ll
// LL: define dso_local i32 @string_literal_test
// RUN: %file-check -vv -check-prefix=CCHECK %s --input-file %t.c
// RUN: %gen-call-checks %t.json > %t.call.checks
// RUN: %file-check -check-prefix=CALL-CHECK %t.call.checks --input-file %t.cir
// CCHECK: sprintf(
// CCHECK: "hello %s"
{
  "architecture": "ARM",
  "id": "ARM:LE:32:Cortex",
  "format": "Executable and Linking Format (ELF)",
  "functions": {
    "ram:10000000": {
      "name": "string_literal_test",
      "is_intrinsic": false,
      "type": {
        "return_type": "type_int",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": ["type_charptr"]
      },
      "basic_blocks": {
        "ram:10000000:entry": {
          "operations": {
            "p0": { "mnemonic": "DECLARE_PARAMETER", "name": "name", "type": "type_charptr", "kind": "parameter", "index": 0 },
            "local_buf": { "mnemonic": "DECLARE_LOCAL", "kind": "local", "name": "buf", "type": "type_charptr" },
            "local_ret": { "mnemonic": "DECLARE_LOCAL", "kind": "local", "name": "ret", "type": "type_int" },
            "br": { "mnemonic": "BRANCH", "target_block": "ram:10000000:0:basic" }
          },
          "ordered_operations": ["p0", "local_buf", "local_ret", "br"]
        },
        "ram:10000000:0:basic": {
          "operations": {
            "addr_buf": {
              "mnemonic": "ADDRESS_OF",
              "type": "type_charptr",
              "inputs": [{ "type": "type_arr64", "kind": "local", "operation": "local_buf" }]
            },
            "fmt_str": {
              "mnemonic": "COPY",
              "type": "type_charptr",
              "inputs": [{ "type": "type_charptr", "kind": "string", "string_value": "hello %s" }]
            },
            "call_sprintf": {
              "mnemonic": "CALL",
              "type": "type_int",
              "output": { "kind": "local", "operation": "local_ret" },
              "has_return_value": true,
              "target": { "kind": "function", "function": "EXTERNAL:00000001", "is_variadic": true, "is_noreturn": false },
              "inputs": [
                { "type": "type_charptr", "kind": "temporary", "operation": "addr_buf" },
                { "type": "type_charptr", "kind": "temporary", "operation": "fmt_str" },
                { "type": "type_charptr", "kind": "parameter", "operation": "p0" }
              ]
            },
            "ret": {
              "mnemonic": "RETURN",
              "inputs": [{ "type": "type_int", "kind": "local", "operation": "local_ret" }]
            }
          },
          "ordered_operations": ["addr_buf", "fmt_str", "call_sprintf", "ret"]
        }
      },
      "entry_block": "ram:10000000:entry"
    },
    "EXTERNAL:00000001": {
      "name": "sprintf",
      "is_intrinsic": false,
      "type": { "return_type": "type_int", "is_variadic": true, "is_noreturn": false, "parameter_types": ["type_charptr", "type_charptr"] }
    }
  },
  "globals": {},
  "types": {
    "type_int": { "name": "int", "size": 4, "kind": "integer", "is_signed": true },
    "type_char": { "name": "char", "size": 1, "kind": "integer" },
    "type_charptr": { "kind": "pointer", "size": 4, "element_type": "type_char" },
    "type_arr64": { "kind": "array", "size": 64, "num_elements": 64, "element_type": "type_char" }
  }
}
