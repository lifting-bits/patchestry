// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -use-structuring-pass -emit-cir -emit-llvm -print-tu -output %t >> /dev/null 2>&1
// RUN: test -e %t.c
// RUN: %file-check -vv -check-prefix=CCHECK %s --input-file %t.c
// CCHECK: arr[
// RUN: %file-check -vv -check-prefix=FN %s --input-file %t.cir
// FN: cir.func @ptradd_array_test(
// RUN: %file-check -vv -check-prefix=LL %s --input-file %t.ll
// LL: define dso_local i32 @ptradd_array_test
// LL: getelementptr
//
// PTRADD should generate array subscript syntax: arr[idx]
// This tests the PTRADD → array subscript transformation in OperationStmt.
//
{
  "architecture": "ARM",
  "id": "ARM:LE:32:Cortex",
  "format": "Executable and Linking Format (ELF)",
  "functions": {
    "ram:10000000": {
      "name": "ptradd_array_test",
      "is_intrinsic": false,
      "type": {
        "return_type": "type_int",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": ["type_intptr", "type_int"]
      },
      "basic_blocks": {
        "ram:10000000:entry": {
          "operations": {
            "p0": { "mnemonic": "DECLARE_PARAMETER", "name": "arr", "type": "type_intptr", "kind": "parameter", "index": 0 },
            "p1": { "mnemonic": "DECLARE_PARAMETER", "name": "idx", "type": "type_int", "kind": "parameter", "index": 1 },
            "br": { "mnemonic": "BRANCH", "target_block": "ram:10000000:0:basic" }
          },
          "ordered_operations": ["p0", "p1", "br"]
        },
        "ram:10000000:0:basic": {
          "operations": {
            "ptr_add": {
              "mnemonic": "PTRADD",
              "type": "type_intptr",
              "inputs": [
                { "type": "type_intptr", "kind": "parameter", "operation": "p0" },
                { "type": "type_int", "kind": "parameter", "operation": "p1" },
                { "type": "type_int", "kind": "constant", "value": 4 }
              ]
            },
            "load_elem": {
              "mnemonic": "LOAD",
              "type": "type_int",
              "inputs": [{ "type": "type_intptr", "kind": "temporary", "operation": "ptr_add" }]
            },
            "ret": {
              "mnemonic": "RETURN",
              "inputs": [{ "type": "type_int", "kind": "temporary", "operation": "load_elem" }]
            }
          },
          "ordered_operations": ["ptr_add", "load_elem", "ret"]
        }
      },
      "entry_block": "ram:10000000:entry"
    }
  },
  "globals": {},
  "types": {
    "type_int": { "name": "int", "size": 4, "kind": "integer" },
    "type_intptr": { "kind": "pointer", "size": 4, "element_type": "type_int" }
  }
}
