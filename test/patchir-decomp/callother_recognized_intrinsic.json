// RUN: %file-check -vv -check-prefix=LL %s --input-file %t.ll
// CIR: cir.func dso_local @volatile_read_test
// CIR: cir.load
// LL: define dso_local i32 @volatile_read_test
// LL: load
{
  "architecture": "ARM",
  "id": "ARM:LE:32:Cortex",
  "format": "Executable and Linking Format (ELF)",
  "functions": {
    "ram:10000000": {
      "name": "volatile_read_test",
      "is_intrinsic": false,
      "type": {
        "return_type": "type_int",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": ["type_ptr_int"]
