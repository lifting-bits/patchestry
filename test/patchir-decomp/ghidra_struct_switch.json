// RUN: bash %strip-json-comments %s > %t.json
// RUN: %patchir-decomp -input %t.json -use-structuring-pass -use-rellic-transform=false -print-tu -output %t >> /dev/null 2>&1
// RUN: %file-check -vv -check-prefix=SW %s --input-file %t.c
//
// NOTE: This test intentionally omits -emit-cir -emit-llvm.
// CollapseStructure may emit goto statements inside switch case bodies that
// reference case-entry labels. CIR lowering does not support goto/label pairs
// that cross switch-case boundaries, causing a goto/label mismatch abort.
// This is a known CIR limitation (not a CollapseStructure bug). The C output
// is correct and verified by the CHECK lines below.
//
// SW: switch (
// SW: case {{[0-9]+[U]?}}:
// SW: case {{[0-9]+[U]?}}:
// SW: case {{[0-9]+[U]?}}:
{
  "architecture": "ARM",
  "id": "ARM:LE:32:Cortex",
  "format": "Executable and Linking Format (ELF)",
  "functions": {
    "ram:16000000": {
      "name": "ghidra_struct_switch",
      "is_intrinsic": false,
      "type": {
        "return_type": "type_void",
        "is_variadic": false,
        "is_noreturn": false,
        "parameter_types": ["type_int"]
      },
      "basic_blocks": {
        "ram:16000000:entry": {
          "operations": {
            "decl_p0": { "mnemonic": "DECLARE_PARAMETER", "name": "selector", "type": "type_int", "kind": "parameter", "index": 0 },
            "br": { "mnemonic": "BRANCH", "target_block": "ram:16000000:0:basic" }
          },
          "ordered_operations": ["decl_p0", "br"]
        },
        "ram:16000000:0:basic": {
          "operations": {
            "ind": {
              "mnemonic": "BRANCHIND",
              "inputs": [
                { "type": "type_int", "kind": "parameter", "operation": "decl_p0" }
              ],
              "switch_cases": [
                { "value": 5, "target_block": "ram:16000000:1:basic", "has_exit": false },
                { "value": 6, "target_block": "ram:16000000:2:basic", "has_exit": false },
                { "value": 7, "target_block": "ram:16000000:4:basic", "has_exit": false }
              ],
              "fallback_block": "ram:16000000:3:basic"
            }
          },
          "ordered_operations": ["ind"]
        },
        "ram:16000000:1:basic": {
          "operations": {
            "ret1": { "mnemonic": "RETURN", "inputs": [] }
          },
          "ordered_operations": ["ret1"]
        },
        "ram:16000000:2:basic": {
          "operations": {
            "ret2": { "mnemonic": "RETURN", "inputs": [] }
          },
          "ordered_operations": ["ret2"]
        },
        "ram:16000000:4:basic": {
          "operations": {
            "ret4": { "mnemonic": "RETURN", "inputs": [] }
          },
          "ordered_operations": ["ret4"]
        },
        "ram:16000000:3:basic": {
          "operations": {
            "ret3": { "mnemonic": "RETURN", "inputs": [] }
          },
          "ordered_operations": ["ret3"]
        }
      },
      "entry_block": "ram:16000000:entry"
    }
  },
  "globals": {},
  "types": {
    "type_int":  { "name": "int",  "size": 4, "kind": "integer" },
    "type_void": { "name": "void", "size": 0, "kind": "void"    },
    "type_ptr":  { "kind": "pointer", "size": 4, "element_type": "type_void" }
  }
}
